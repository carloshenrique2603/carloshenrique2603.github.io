body {
  margin: 0;
  font-family: Arial, sans-serif;
  background: #121212;
  color: white;
}

.app {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100vh;
}

.player-card {
  background: #1e1e1e;
  padding: 30px;
  border-radius: 20px;
  text-align: center;
  width: 300px;
  box-shadow: 0 0 30px rgba(0,0,0,0.5);
}

.cover {
  width: 100%;
  height: 200px;
  background: url('https://images.unsplash.com/photo-1511376777868-611b54f68947') center/cover;
  border-radius: 15px;
  margin: 20px 0;
}

button {
  font-size: 30px;
  border: none;
  background: #1db954;
  color: white;
  width: 70px;
  height: 70px;
  border-radius: 50%;
  cursor: pointer;
}

button:hover {
  background: #1ed760;
}

h2 {
  font-size: 18px;
  margin: 10px 0;
}
