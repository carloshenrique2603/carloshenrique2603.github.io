body {
  margin: 0;
  font-family: Arial, sans-serif;
  background: linear-gradient(180deg, #000000, #111);
  color: white;
  text-align: center;
}

/* TOPO */
.topo {
  padding: 30px 0;
}

.logo {
  width: 180px;
}

.topo h1 {
  margin-top: 10px;
  font-size: 28px;
  color: #ffcc00;
}

/* LOCUTOR */
.locutor {
  margin: 40px auto;
  padding: 20px;
  width: 80%;
  max-width: 400px;
  background: #1a1a1a;
  border-radius: 15px;
  box-shadow: 0 0 20px rgba(255, 204, 0, 0.4);
}

.locutor p {
  margin: 0;
  font-size: 14px;
  color: #aaa;
}

.locutor h2 {
  margin: 10px 0 0;
  font-size: 32px;
  color: #ffcc00;
}

/* PLAYER */
.player {
  margin-top: 40px;
}

audio {
  margin-top: 10px;
  width: 250px;
}
