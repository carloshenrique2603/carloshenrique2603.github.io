body {
  margin: 0;
  font-family: Arial;
  background: #121212;
  color: white;
}

.app {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100vh;
}

.player {
  background: #1e1e1e;
  padding: 30px;
  border-radius: 20px;
  width: 320px;
  text-align: center;
}

.cover {
  width: 100%;
  height: 200px;
  background: url('https://images.unsplash.com/photo-1511376777868-611b54f68947') center/cover;
  border-radius: 15px;
  margin: 20px 0;
}

button {
  width: 70px;
  height: 70px;
  border-radius: 50%;
  border: none;
  font-size: 25px;
  background: #1db954;
  color: white;
  cursor: pointer;
}

button:hover {
  background: #1ed760;
}

.live {
  color: red;
  animation: pulse 1s infinite;
}

@keyframes pulse {
  0% {opacity: 1;}
  50% {opacity: 0.3;}
  100% {opacity: 1;}
}
