body {
  margin: 0;
  font-family: 'Segoe UI', sans-serif;
  background: linear-gradient(180deg, #0f2027, #203a43, #121212);
  color: white;
}

.app {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100vh;
}

/* CARD PRINCIPAL */
.player {
  background: rgba(30,30,30,0.9);
  padding: 30px;
  border-radius: 25px;
  width: 320px;
  text-align: center;
  backdrop-filter: blur(10px);
  box-shadow: 0 0 40px rgba(0,0,0,0.8);
}

/* LOGO */
.logo {
  font-size: 24px;
  font-weight: bold;
}

.logo span {
  color: #1db954;
}

/* AO VIVO */
.live {
  margin-top: 10px;
  color: #ff3b3b;
  font-weight: bold;
  animation: pulse 1s infinite;
}

@keyframes pulse {
  0% {opacity: 1;}
  50% {opacity: 0.3;}
  100% {opacity: 1;}
}

/* CAPA */
.cover {
  width: 100%;
  height: 200px;
  margin: 20px 0;
  border-radius: 20px;
  background: linear-gradient(45deg, #1db954, #191414);
  box-shadow: 0 0 20px #1db954;
  animation: glow 3s infinite alternate;
}

@keyframes glow {
  from {box-shadow: 0 0 10px #1db954;}
  to {box-shadow: 0 0 30px #1db954;}
}

/* BOTÃO PLAY */
button {
  width: 80px;
  height: 80px;
  border-radius: 50%;
  border: none;
  font-size: 30px;
  background: #1db954;
  color: white;
  cursor: pointer;
  transition: 0.3s;
}

button:hover {
  transform: scale(1.1);
  background: #1ed760;
}

h2 {
  font-size: 16px;
}
