body {
  margin: 0;
  font-family: Arial;
  text-align: center;
  color: white;
  background: linear-gradient(-45deg, #000, #111, #1a1a1a, #000);
  background-size: 400% 400%;
  animation: fundo 10s infinite;
}

/* ANIMAÇÃO FUNDO */
@keyframes fundo {
  0% {background-position: 0%}
  50% {background-position: 100%}
  100% {background-position: 0%}
}

/* LOGO */
.logo {
  width: 160px;
  margin-top: 20px;
}

h1 {
  color: #ffcc00;
}

/* FRASES */
.frases {
  margin: 20px;
  font-size: 18px;
  color: #ccc;
}

/* LOCUTOR */
.locutor {
  margin: 30px auto;
  padding: 15px;
  width: 85%;
  max-width: 350px;
  background: #1a1a1a;
  border-radius: 15px;
}

/* AO VIVO PULSANDO */
.ao-vivo {
  color: red;
  font-weight: bold;
  animation: pulse 1s infinite;
}

@keyframes pulse {
  0% {opacity: 1;}
  50% {opacity: 0.3;}
  100% {opacity: 1;}
}

/* NOME */
.locutor h2 {
  font-size: 30px;
  color: #ffcc00;
}

/* BOTÃO */
#botao {
  margin-top: 30px;
  padding: 15px 40px;
  font-size: 20px;
  border: none;
  border-radius: 30px;
  background: #ffcc00;
  color: black;
  font-weight: bold;
  cursor: pointer;
  transition: 0.3s;
}

#botao:hover {
  background: #ffaa00;
}
